<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dynamic Form Add/Remove</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
</head>

<body class="bg-light">

    <div class="container mt-5">
        <h3 class="text-center mb-4">Dynamic Form Using Bootstrap & jQuery</h3>

        <form id="mainForm">
            <div id="formContainer">
                <div class="form-row align-items-end mb-3 form-section">
                    <div class="col-md-5">
                        <label>Name</label>
                        <input type="text" class="form-control" placeholder="Enter Name">
                    </div>
                    <div class="col-md-5">
                        <label>Email</label>
                        <input type="email" class="form-control" placeholder="Enter Email">
                    </div>
                    <div class="col-md-2 text-right">
                        <button type="button" class="btn btn-success btn-add">+</button>
                        <button type="button" class="btn btn-danger btn-remove">-</button>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-primary mt-3">Submit</button>
        </form>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            
            $(document).on('click', '.btn-add', function () {
                let formSection = $(this).closest('.form-section').clone();
                formSection.find('input').val(''); 
                $('#formContainer').append(formSection);
            });

           
            $(document).on('click', '.btn-remove', function () {
                if ($('.form-section').length > 1) {
                    $(this).closest('.form-section').remove();
                } else {
                    alert("At least one form section is required!");
                }
            });
        });
    </script>

</body>

</html>
